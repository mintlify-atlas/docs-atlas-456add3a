  "keyFeatures": [
    "Automated security checks for open source projects on GitHub and GitLab",
    "18+ security checks covering branch protection, code review, dependency management, and more",
    "Probe-based architecture for fine-grained, composable security analysis",
    "GitHub Action integration for continuous security monitoring",
    "REST API for querying pre-calculated scores of 1M+ open source projects",
    "Maintainer annotations to provide context for check results",
    "Multiple output formats: default, JSON, SARIF, in-toto",
    "Policy files for enforcing security requirements in CI/CD",
    "Support for GitHub, GitLab, and Azure DevOps repositories",
    "Public BigQuery dataset with weekly scans of top open source projects"
  ],
  "publicApiSurface": [
    "scorecard --repo=<repo>",
    "scorecard --local=<folder>",
    "scorecard --org=<organization>",
    "scorecard --npm=<package> / --pypi=<package> / --rubygems=<package> / --nuget=<package>",
    "scorecard --checks=<check1,check2,...>",
    "scorecard --probes=<probe1,probe2,...>",
    "scorecard --format=<default|json|sarif|probe|raw|intoto>",
    "scorecard --show-details",
    "scorecard --show-annotations",
    "scorecard --policy=<policy-file>",
    "scorecard serve",
    "scorecard version",
    "scorecard.Run(ctx, repo, opts...) (pkg/scorecard)",
    "GET|POST / (HTTP serve endpoint)",
    "GET /health (HTTP serve health check)"
  ]
}
